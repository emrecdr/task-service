# =============================================================================
# Internal Task Service — .gitignore
# Based on github/gitignore/Python.gitignore, trimmed and project-specific.
# =============================================================================

# -----------------------------------------------------------------------------
# Byte-compiled / optimised / dynamic-link
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# -----------------------------------------------------------------------------
# Distribution / packaging
# -----------------------------------------------------------------------------
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec

# -----------------------------------------------------------------------------
# Virtualenvs (uv writes to .venv/ by default)
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version.local

# -----------------------------------------------------------------------------
# Test / coverage artifacts
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.cache/
.tox/
.nox/
nosetests.xml
*.cover
*.py,cover
.hypothesis/

# -----------------------------------------------------------------------------
# Static analysis caches
# -----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# -----------------------------------------------------------------------------
# Environment files (only .env.example is checked in — FRD §6.1)
# -----------------------------------------------------------------------------
.env
.env.local
.env.dev
.env.test
.env.qa
.env.prod
.env.*.local

# -----------------------------------------------------------------------------
# Hurl / Schemathesis reports
# -----------------------------------------------------------------------------
reports/
!reports/.gitkeep
!reports/hurl/.gitkeep

# -----------------------------------------------------------------------------
# Logs and runtime artifacts
# -----------------------------------------------------------------------------
*.log
logs/
*.pid
*.sock

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
docker-compose.override.yaml
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Editors / IDEs
# -----------------------------------------------------------------------------
.idea/
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~
.history/

# -----------------------------------------------------------------------------
# Jupyter / notebooks (in case anyone scratches)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# OS artifacts
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Direnv / mise / asdf
# -----------------------------------------------------------------------------
.envrc
.tool-versions.local

# -----------------------------------------------------------------------------
# Secrets — extra belt-and-braces, never check these in
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
secrets/
.secrets/

.history
